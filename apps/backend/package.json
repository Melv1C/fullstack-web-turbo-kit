{
  "name": "backend",
  "version": "0.0.0",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "add-admin": "bun ./scripts/add-admin.ts",
    "build": "vp pack",
    "dev": "APP_ENV=development concurrently \"vp pack --watch\" \"tsx watch src/index.ts\"",
    "env:generate": "varlock typegen",
    "env:validate": "varlock load",
    "prisma:format": "APP_ENV=development prisma format",
    "prisma:generate": "APP_ENV=development prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:validate": "APP_ENV=development prisma validate",
    "start": "npm run prisma:migrate:deploy && bun src/index.ts",
    "sync-json-data": "bun ./scripts/sync-json-data.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/studio-core": "^0.27.3",
    "@repo/utils": "workspace:*",
    "better-auth": "^1.5.6",
    "hono": "^4.12.10",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "varlock": "^0.7.1",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.15"
  }
}
