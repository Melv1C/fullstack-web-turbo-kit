# Shared env schema for varlock (imported by app schemas)
# @currentEnv=$APP_ENV
# @defaultSensitive=false @defaultRequired=false
# ---

# Environment flag
# @type=enum(development, staging, production, test) @required
APP_ENV=development

# CI flag (set to true in CI environments)
# @type=boolean @required
CI=false

# Port configurations
# @type=port @required=forEnv(development)
FRONTEND_PORT=5173
# @type=port @required=forEnv(development)
ADMIN_PORT=5174
# @type=port @required
BACKEND_PORT=3000

# Shared URLs (derived from APP_ENV)
# @required
BACKEND_URL=ifs(
  forEnv(production, staging), MY_APP_BACKEND_URL,
  forEnv(development, test), "http://localhost:${BACKEND_PORT}",
  undefined
)
# @required
FRONTEND_URL=ifs(
  forEnv(production, staging), MY_APP_FRONTEND_URL, 
  forEnv(development, test), "http://localhost:${FRONTEND_PORT}",
  undefined
)
# @required
ADMIN_URL=ifs(
  forEnv(production, staging), MY_APP_ADMIN_URL, 
  forEnv(development, test), "http://localhost:${ADMIN_PORT}",
  undefined
)
