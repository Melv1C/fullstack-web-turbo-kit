{
  "name": "fullstack-web-turbo-kit",
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:local": "turbo run build:local",
    "build:staging": "turbo run build:staging",
    "build:production": "turbo run build:production",
    "dev": "turbo run dev --ui=tui",
    "docker:db": "docker compose -f docker-compose.db.yml up -d",
    "docker:db:down": "docker compose -f docker-compose.db.yml down",
    "lint": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "bunx knip",
    "deps": "bunx npm-check-updates",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "deps:interactive": "bunx npm-check-updates -i",
    "prisma:generate": "bun --filter backend prisma:generate",
    "prisma:migrate": "bun --filter backend prisma:migrate",
    "prisma:migrate:deploy": "bun --filter backend prisma:migrate:deploy",
    "prisma:validate": "bun --filter backend prisma:validate",
    "prisma:format": "bun --filter backend prisma:format",
    "release:prepare": "bunx changeset",
    "release:publish": "./scripts/release.sh",
    "env:generate": "turbo run env:generate",
    "env:validate": "turbo run env:validate",
    "prepare": "husky"
  },
  "dependencies": {
    "varlock": "^0.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "turbo": "^2.8.19",
    "typescript": "5.9.3"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.4",
    "@rollup/rollup-linux-x64-gnu": "4.59.0"
  },
  "packageManager": "bun@1.3.11"
}
