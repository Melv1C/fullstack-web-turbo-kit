{
  "name": "fullstack-web-turbo-kit",
  "version": "0.0.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:local": "turbo run build:local",
    "build:production": "turbo run build:production",
    "build:staging": "turbo run build:staging",
    "check": "vp check",
    "deps": "ncu",
    "dev": "turbo run dev --ui=tui",
    "docker:db": "docker compose -f docker-compose.db.yml up -d",
    "docker:db:down": "docker compose -f docker-compose.db.yml down",
    "env:generate": "turbo run env:generate",
    "env:validate": "turbo run env:validate",
    "format": "vp fmt",
    "knip": "bunx knip",
    "lint": "vp lint",
    "lockfile:sync": "bun scripts/sync-bun-lock.ts",
    "prisma:format": "bun run --filter @repo/database prisma:format",
    "prisma:generate": "bun run --filter @repo/database prisma:generate",
    "prisma:migrate": "bun run --filter @repo/database prisma:migrate",
    "prisma:migrate:deploy": "bun run --filter @repo/database prisma:migrate:deploy",
    "prisma:validate": "bun run --filter @repo/database prisma:validate",
    "release:prepare": "changeset",
    "release:push": "./scripts/release-push.sh",
    "release:version": "./scripts/release-version.sh",
    "test": "turbo run test"
  },
  "dependencies": {
    "varlock": "^1.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@repo/typescript-config": "workspace:*",
    "eslint-plugin-zod": "^4.5.3",
    "npm-check-updates": "^22.2.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.16",
    "typescript": "6.0.3",
    "vite-plus": "^0.1.23"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.9",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.12",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@varlock/vite-integration": "^1.1.2",
    "@vitejs/plugin-react": "^6.0.2",
    "better-auth": "^1.6.11",
    "hono": "^4.12.23",
    "i18next": "^26.3.0",
    "lucide-react": "^1.17.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "varlock": "^1.3.0",
    "vite-plus": "^0.1.23",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
